{
  "pluginAlias": "PersistentAlarm",
  "pluginType": "platform",
  "singular": true,
  "strictValidation": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "platform": {
        "type": "string",
        "default": "PersistentAlarm"
      },
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "Persistent Alarm"
      },
      "debug": {
        "title": "Debug Logging",
        "type": "boolean",
        "default": false
      },
      "alarms": {
        "title": "Persistent Alarms",
        "type": "array",
        "default": [],
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "name", "delaySeconds", "motionDurationSeconds", "repeatMode"],
          "properties": {
            "id": {
              "title": "Stable Alarm ID",
              "type": "string",
              "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$",
              "description": "Stable internal ID used for persistence and HomeKit UUIDs. Do not change this when renaming an alarm."
            },
            "name": {
              "title": "HomeKit Name",
              "type": "string"
            },
            "delaySeconds": {
              "title": "Delay Before Trigger",
              "type": "integer",
              "minimum": 1,
              "maximum": 31622400,
              "description": "Delay in seconds before the first trigger and between repeat occurrences."
            },
            "motionDurationSeconds": {
              "title": "Motion Active Duration",
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 86400,
              "description": "How long the motion sensor remains active after a scheduled trigger."
            },
            "repeatMode": {
              "title": "Repeat Mode",
              "type": "string",
              "default": "once",
              "oneOf": [
                { "title": "Once", "enum": ["once"] },
                { "title": "Fixed number of triggers", "enum": ["count"] },
                { "title": "Until cancelled", "enum": ["infinite"] }
              ]
            },
            "repeatCount": {
              "title": "Repeat Count",
              "type": "integer",
              "default": 1,
              "minimum": 1,
              "maximum": 10000,
              "description": "Total number of triggers including the first one. Used only when Repeat Mode is Fixed number of triggers."
            },
            "homekitExposure": {
              "title": "HomeKit Exposure",
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "cancelSwitch": {
                  "title": "Expose Cancel and Reset Switch",
                  "type": "boolean",
                  "default": true
                }
              }
            }
          }
        }
      }
    }
  }
}
