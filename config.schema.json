{
  "pluginAlias": "PersistentAlarm",
  "pluginType": "platform",
  "singular": true,
  "strictValidation": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "platform": {
        "type": "string",
        "default": "PersistentAlarm"
      },
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "Persistent Alarm"
      },
      "debug": {
        "title": "Debug Logging",
        "type": "boolean",
        "default": false
      },
      "alarms": {
        "title": "Persistent Alarms",
        "type": "array",
        "default": [],
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "name", "delay", "motionDurationSeconds", "repeatMode"],
          "properties": {
            "id": {
              "title": "Stable Alarm ID",
              "type": "string",
              "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$",
              "description": "Stable internal ID used for persistence and HomeKit UUIDs. Do not change this when renaming an alarm."
            },
            "name": {
              "title": "HomeKit Name",
              "type": "string"
            },
            "delay": {
              "title": "Delay Before Trigger",
              "type": "object",
              "additionalProperties": false,
              "description": "Delay before the first trigger and between repeat occurrences.",
              "properties": {
                "hours": {
                  "title": "Hours",
                  "type": "integer",
                  "default": 0,
                  "minimum": 0,
                  "maximum": 168
                },
                "minutes": {
                  "title": "Minutes",
                  "type": "integer",
                  "default": 0,
                  "minimum": 0,
                  "maximum": 59
                },
                "seconds": {
                  "title": "Seconds",
                  "type": "integer",
                  "default": 0,
                  "minimum": 0,
                  "maximum": 59
                }
              }
            },
            "motionDurationSeconds": {
              "title": "Motion Active Duration",
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 86400,
              "description": "How long the motion sensor remains active after a scheduled trigger."
            },
            "repeatMode": {
              "title": "Repeat Mode",
              "type": "string",
              "default": "once",
              "oneOf": [
                { "title": "Once", "enum": ["once"] },
                { "title": "Fixed number of triggers", "enum": ["count"] },
                { "title": "Until cancelled", "enum": ["infinite"] }
              ]
            },
            "repeatCount": {
              "title": "Repeat Count",
              "type": "integer",
              "default": 1,
              "minimum": 1,
              "maximum": 10000,
              "description": "Total number of triggers including the first one. Used only when Repeat Mode is Fixed number of triggers."
            },
            "homekitExposure": {
              "title": "HomeKit Exposure",
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "cancelSwitch": {
                  "title": "Expose Cancel and Reset Switch",
                  "type": "boolean",
                  "default": true
                },
                "remainingTime": {
                  "title": "Expose Remaining Time Accessory",
                  "type": "boolean",
                  "default": false,
                  "description": "Expose a HomeKit valve-style countdown accessory with Remaining Duration for the active schedule."
                }
              }
            },
            "accessoryNames": {
              "title": "Accessory Names",
              "type": "object",
              "additionalProperties": false,
              "description": "Optional full HomeKit names for each accessory. When omitted, names are generated from the HomeKit Name.",
              "properties": {
                "trigger": {
                  "title": "Trigger Accessory Name",
                  "type": "string"
                },
                "motion": {
                  "title": "Motion Accessory Name",
                  "type": "string"
                },
                "reset": {
                  "title": "Reset Accessory Name",
                  "type": "string"
                },
                "countdown": {
                  "title": "Countdown Accessory Name",
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
